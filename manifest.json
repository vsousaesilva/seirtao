{
  "manifest_version": 3,
  "name": "SEIrtão",
  "version": "0.1.0",
  "description": "SEIrtão — Assistente com IA integrado ao SEI (Sistema Eletrônico de Informações) do TRF5. Resumo de processos, sugestão de próximo ato e adaptação de modelos.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://sei.trf5.jus.br/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SEIrtão — Assistente SEI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://sei.trf5.jus.br/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": [
        "*://sei.trf5.jus.br/*"
      ],
      "js": ["sei-main-world.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN",
      "match_origin_as_fallback": true
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/*", "icons/*"],
      "matches": [
        "*://sei.trf5.jus.br/*"
      ]
    }
  ]
}
